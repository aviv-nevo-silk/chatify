{
  "name": "chatify",
  "version": "0.1.0",
  "description": "Outlook add-in that re-renders email threads as a WhatsApp-style chat",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.5",
    "jsdom": "^25.0.1",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^21.1.7"
  },
  "dependencies": {
    "dompurify": "^3.2.0"
  }
}
